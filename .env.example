# Copy to `.env.local` and fill in values. `.env.local` is gitignored.

# Supabase project URL (Dashboard → API). Vercel may use NEXT_PUBLIC_SUPABASE_URL — the app reads both.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase API keys (Dashboard → API). Vercel may use NEXT_PUBLIC_SUPABASE_ANON_KEY — the app reads both.
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Flask → Postgres. First match wins: DATABASE_URL, then POSTGRES_PRISMA_URL, then POSTGRES_URL
# (names used by Vercel “Connect Supabase”). Use the pooler URI on port 6543 for serverless.
# Example (region varies): postgres://postgres.[REF]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

SECRET_KEY=change-me-to-a-long-random-string
OJT_ADMIN_PASSWORD=your-admin-password
